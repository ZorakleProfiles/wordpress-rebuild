---
import type { BlogPost } from "../lib/blog.ts";

interface Props {
  post: BlogPost;
  basePath?: string;
}

const { post, basePath = "/blog" } = Astro.props;

const publishedDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric"
}).format(new Date(post.publishedAt));

let slug = post.slug.replace('wordpress-import/', '');
const postUrl = `/${slug}`;
---

<article class="grid gap-5 border-b border-[#d1d4dd] py-8 md:grid-cols-[220px_minmax(0,1fr)] md:items-start">
  <a href={postUrl} class="block overflow-hidden rounded-sm border border-[#e2e5ec] bg-[#f0f1f5]">
    {
      post.featuredImageUrl ? (
        <img
          src={post.featuredImageUrl}
          alt={post.featuredImageAlt || post.title}
          class="h-35 w-full object-cover"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="flex h-35 items-center justify-center text-sm text-[#8a8e98]">Thumbnail</div>
      )
    }
  </a>

  <div>
    <h2 class="font-display text-[34px] leading-tight text-[#22252a] md:text-[38px]">
      <a href={postUrl} class="transition hover:text-[#fd7730]">{post.title}</a>
    </h2>
    <p class="mt-3 text-sm font-semibold text-[#22252a]">Posted on {publishedDate}</p>
    <p class="mt-4 text-base leading-relaxed text-[#3b3e47]">{post.excerpt}</p>
  </div>
</article>
