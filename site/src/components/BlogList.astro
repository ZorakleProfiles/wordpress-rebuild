---
import MainLayout from "../layouts/MainLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";
import BlogCard from "./BlogCard.astro";
import PaginationNav from "./PaginationNav.astro";
import type { BlogPost } from "../lib/blog.ts";

interface Props {
  title: string;
  description: string;
  heading: string;
  emptyStateMessage: string;
  basePath: string;
  postBasePath?: string;
  posts: BlogPost[];
  currentPage: number;
  totalPages: number;
}

const {
  title,
  description,
  heading,
  emptyStateMessage,
  basePath,
  postBasePath = basePath,
  posts,
  currentPage,
  totalPages
} = Astro.props;
---

<MainLayout title={title} description={description}>
  <SiteHeader />

  <main class="bg-[#f7f8fb] py-14 md:py-16">
    <section class="section-shell">
      <h1 class="font-display text-[40px] leading-tight text-[#22252a] md:text-[52px]">{heading}</h1>

      {
        posts.length > 0 ? (
          <div class="mt-6 rounded-xl bg-white px-6 py-2 shadow-sm md:px-8">
            {posts.map((post) => (
              <BlogCard post={post} basePath={postBasePath} />
            ))}
          </div>
        ) : (
          <div class="mt-8 rounded-xl border border-[#d1d4dd] bg-white p-8 text-[#3b3e47]">{emptyStateMessage}</div>
        )
      }

      <PaginationNav basePath={basePath} currentPage={currentPage} totalPages={totalPages} />
    </section>
  </main>

  <SiteFooter />
</MainLayout>

