---
const url = import.meta.env.PUBLIC_WP_URL;
if (!url) throw new Error('PUBLIC_WP_URL is not defined. Please set it in your .env file or environment.');
const res = await fetch(`${url}/posts?_embed`);
const posts = await res.json();
const postsArray = Array.isArray(posts) ? posts : [];
---
<section class="py-10">
    <div class="mx-auto w-full max-w-4xl px-6">
        <h1 class="mb-12 text-4xl md:text-5xl font-light tracking-tight text-gray-900">Latest News</h1>
        
        <div class="space-y-12">
            {
                postsArray.map((post) => {
                    const featuredImage = post._embedded?.['wp:featuredmedia']?.[0]?.media_details?.sizes?.medium?.source_url;
                    const title = post.title.rendered;
                    const excerpt = post.excerpt.rendered.replace(/<[^>]*>/g, '').replace(/&[a-z]+;/gi, ' ').substring(0, 150);
                    const publishDate = new Date(post.date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric'
                    });
                    
                    return (
                        <a 
                            href={`/wp-update/blog/${post.slug}/`}
                            class="group block transition-opacity hover:opacity-70"
                        >
                            <div class="flex gap-6 items-start">
                                <div class="flex-shrink-0 overflow-hidden rounded-lg">
                                    <img
                                            class="h-40 w-56 object-cover"
                                            src={featuredImage}
                                            alt={title}
                                    />
                                </div>
                                <div class="flex-1">
                                    <h2 class="text-2xl font-semibold text-gray-900 group-hover:text-title-color transition-colors">
                                        {title}
                                    </h2>
                                    <p class="mt-1 text-sm font-medium text-gray-500 uppercase tracking-wide">
                                        {publishDate}
                                    </p>
                                    <p class="mt-3 text-gray-600 line-clamp-2">
                                        {excerpt}...
                                    </p>
                                    <p class="mt-3 text-sm font-medium text-gray-900">
                                        Read article →
                                    </p>
                                </div>
                            </div>
                        </a>
                    );
                })
            }
        </div>
    </div>
</section>

<style>
    :global(.title-color) {
        color: #38ca9d;
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
