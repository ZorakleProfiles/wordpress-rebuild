---
import { Image } from "astro:assets";
import faviconCircle from "../assets/figma-import/favicon-circle.png";

interface Props {
    title?: string;
    text?: string;
    primaryLabel?: string;
    primaryHref?: string;
    secondaryLabel?: string;
    secondaryHref?: string;
}

const {
    title = 'Start predicting your franchise success today.',
    text = "",
    primaryLabel = "Sign Up Now!",
    primaryHref = "#",
    secondaryLabel = "Book a Demo",
    secondaryHref = "#"
} = Astro.props;
---

<section class="bg-[#09cc9c] pb-26 pt-12 footer-cta">
  <div class="section-shell flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl">
      <h2 set:html={title}
              class="font-display text-5xl leading-[1.05] text-white md:text-6xl font-bold">
      </h2>
      <p class="mt-5 text-lg text-white/85">
          {text}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
         <a class="inline-flex items-center justify-center rounded-lg bg-[#fd7730] px-7 py-3 text-base font-bold text-white transition hover:brightness-95 whitespace-nowrap" href={primaryHref}>{primaryLabel}</a>
         <a class="inline-flex items-center justify-center rounded-lg border border-white/40 bg-transparent px-7 py-3 text-base font-bold text-white transition hover:bg-white/10 whitespace-nowrap" href={secondaryHref}>{secondaryLabel}</a>
       </div>
    </div>
  </div>
</section>
<style is:global>
    .footer-cta {
        margin-bottom: -50px;
    }
    </style>

