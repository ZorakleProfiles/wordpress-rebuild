---
import { differenceCards } from "../data/site-content";
---

<section class="bg-[#f3f3f3] py-20 md:py-24">
  <div class="section-shell">
    <p class="section-eyebrow">The Zorakle Difference</p>
    <h2 class="section-title max-w-4xl">
      Why Zorakle isn't another assessment tool.
    </h2>

    <div class="mt-10 grid gap-6 md:mt-12 md:grid-cols-3 md:gap-7">
      {differenceCards.map((card) => (
        <article class="rounded-2xl border border-white bg-white p-8">
          <p class="text-5xl font-bold text-[#09cc9c]">{card.index}</p>
          <h3 class="mt-6 text-2xl font-bold text-[#22252a]">{card.title}</h3>
          <p class="mt-4 text-base leading-relaxed text-[#3b3e47]">{card.description}</p>
        </article>
      ))}
    </div>
    <div class="mt-10 flex flex-wrap justify-center gap-3 md:mt-12">
      <a class="btn-primary" href="#">Sign Up Now!</a>
      <a class="btn-secondary btn-secondary-dark" href="/schedule">Book a Demo</a>
    </div>
  </div>
</section>

