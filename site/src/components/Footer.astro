---
import logo from "../assets/figma/logo.png";
import { withBase } from "../utils/paths";
const logoSrc = logo.src;
---

<footer class="site-footer">
  <div class="container footer-grid compact-footer-grid">
    <div class="footer-brand-wrap">
      <img src={logoSrc} width="150" height="40" alt="Zorakle" />
      <p>Zorakle Profiles, LLC 8782 S. Park Road Rogers, AR 72756</p>
      <a href="mailto:support@zorakle.net">support@zorakle.net</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© 2026 Zorakle. All Rights Reserved.</p>
    <a href={withBase("/privacy")}>Privacy Policy</a>
  </div>
</footer>

