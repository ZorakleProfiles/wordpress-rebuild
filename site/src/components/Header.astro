---
import { navLinks } from "../data/siteData";
import logo from "../assets/figma/logo.png";
import { withBase } from "../utils/paths";
import { HUBSPOT_MEETINGS_URL } from "../config/site";

const logoSrc = logo.src;
const basePrefix = import.meta.env.BASE_URL.replace(/\/$/, "");
const strippedPath = basePrefix && Astro.url.pathname.startsWith(basePrefix)
  ? Astro.url.pathname.slice(basePrefix.length)
  : Astro.url.pathname;
const currentPath = strippedPath || "/";

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};

const isLinkActive = (link: { href: string; children?: { href: string }[] }) => {
  if (isActive(link.href)) return true;
  return Boolean(link.children?.some((child) => isActive(child.href)));
};

---

<header class="site-header">
  <div class="container header-inner">
    <a href={withBase("/")} class="brand" aria-label="Zorakle home">
      <img src={logoSrc} width="180" height="48" alt="Zorakle" />
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {navLinks.map((link) => (
          <li class={link.children ? "nav-item has-dropdown" : "nav-item"}>
              <a href={withBase(link.href)} class={isLinkActive(link) ? "nav-link is-active" : "nav-link"} aria-current={isLinkActive(link) ? "page" : undefined}>
              {link.label}
              {link.children && <span class="nav-caret" aria-hidden="true">▾</span>}
            </a>

            {link.children && (
              <ul class="dropdown-menu" aria-label={`${link.label} submenu`}>
                {link.children.map((child) => (
                  <li>
                    <a href={withBase(child.href)} class={isActive(child.href) ? "dropdown-link is-active" : "dropdown-link"}>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header-cta">
      <a class="btn btn-outline" href={HUBSPOT_MEETINGS_URL} target="_blank" rel="noopener noreferrer">Book a Demo</a>
      <a class="btn btn-ghost" href={withBase("/login")}>Login</a>
    </div>
  </div>
</header>

