---
import heroBackground from "../assets/figma-import/hero-background.png";
import { hero } from "../data/site-content";
import PageHero from "./PageHero.astro";
---

<PageHero
  eyebrow={hero.eyebrow}
  titlePrefix={hero.titlePrefix}
  titleHighlight={hero.titleAccent}
  description={hero.description}
  primaryCta={hero.primaryCta}
  secondaryCta={hero.secondaryCta}
  backgroundImage={heroBackground}
  dark={true}
/>

