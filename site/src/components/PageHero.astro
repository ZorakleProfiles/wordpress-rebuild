---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  eyebrow?: string;
  titlePrefix: string;
  titleHighlight?: string;
  titleSuffix?: string;
  description?: string;
  primaryCta?: { href: string; label: string };
  secondaryCta?: { href: string; label: string };
  backgroundImage?: ImageMetadata;
  backgroundColor?: string;
  dark?: boolean;
  overlayClass?: string;
  minHeightClass?: string;
  rightImage?: ImageMetadata;
}

const {
  eyebrow,
  titlePrefix,
  titleHighlight,
  titleSuffix,
  description,
  primaryCta,
  secondaryCta,
  backgroundImage,
  backgroundColor = "#d5dbeb",
  dark = false,
  overlayClass = "bg-[#1f232a]/[0.8]",
  minHeightClass = "min-h-[70vh] md:min-h-[100vh]",
  rightImage
} = Astro.props;

const sectionStyle = backgroundImage
  ? `background-image: url(${backgroundImage.src});`
  : `background-color: ${backgroundColor};`;

const textColorClass = dark ? "text-white" : "text-[#1f232a]";
const bodyColorClass = dark ? "text-white" : "text-[#3b3e47]";
---

<section
  class="relative overflow-hidden border-b border-[#d1d4dd] bg-cover bg-center bg-no-repeat"
  style={sectionStyle}
>
  {backgroundImage && <div class={`absolute inset-0 z-0 ${overlayClass}`}></div>}

  <div class={`section-shell relative z-10 flex flex-col gap-8 py-14 md:flex-row md:items-start md:gap-10 md:py-20 ${minHeightClass}`}>
    <div class={`${rightImage ? "w-full md:max-w-[55%]" : "w-full md:max-w-[70%]"} space-y-4 md:space-y-6`}>
      {eyebrow && (
        <p class={`font-display text-base md:text-[20px] ${dark ? "text-white/90" : "text-[#09cc9c]"}`}>
          {eyebrow}
        </p>
      )}

      <div class={`font-display text-4xl font-bold leading-tight sm:text-5xl md:text-6xl ${textColorClass}`}>
        {titlePrefix}
        {titleHighlight && <span class="text-[#09cc9c]"><br>{titleHighlight}</span>}
        {titleSuffix && ` ${titleSuffix}`}
      </div>

      {description && <p class={`max-w-140 text-sm leading-relaxed sm:text-base md:text-lg ${bodyColorClass}`}>{description}</p>}

      {(primaryCta || secondaryCta) && (
        <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:flex-wrap">
          {primaryCta && (
            <a href={primaryCta.href} class="btn-primary w-full text-center sm:w-auto">
              {primaryCta.label}
            </a>
          )}
          {secondaryCta && (
            <a href={secondaryCta.href} class="btn-primary w-full text-center sm:w-auto">
              {secondaryCta.label}
            </a>
          )}
        </div>
      )}
    </div>
    {rightImage && (
      <div class="flex w-full items-center justify-center md:flex-1">
        <Image src={rightImage} alt="Hero Visual" class="h-auto max-w-[320px] object-contain sm:max-w-105 md:max-w-full" />
      </div>
    )}
  </div>
</section>

