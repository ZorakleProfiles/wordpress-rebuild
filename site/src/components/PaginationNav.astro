---
interface Props {
  basePath: string;
  currentPage: number;
  totalPages: number;
}

const { basePath, currentPage, totalPages } = Astro.props;

const buildPageHref = (page: number): string => {
  return page <= 1 ? `${basePath}/` : `${basePath}/page/${page}/`;
};

const pagesToRender = new Set<number>([1, totalPages, currentPage - 1, currentPage, currentPage + 1]);
const visiblePages = [...pagesToRender]
  .filter((page) => page >= 1 && page <= totalPages)
  .sort((a, b) => a - b);

const pageItems: Array<{ type: "page"; value: number } | { type: "gap"; value: string }> = [];
let previousPage = 0;
for (const page of visiblePages) {
  if (previousPage && page - previousPage > 1) {
    pageItems.push({ type: "gap", value: `gap-${previousPage}-${page}` });
  }

  pageItems.push({ type: "page", value: page });
  previousPage = page;
}
---

{
  totalPages > 1 && (
    <nav aria-label="Pagination" class="mt-8 flex flex-wrap items-center gap-2 border-t border-[#e5e8ef] pt-6 text-sm font-semibold text-[#3b3e47]">
      {currentPage > 1 ? (
        <a href={buildPageHref(currentPage - 1)} class="rounded-md border border-[#d1d4dd] px-3 py-1.5 transition hover:border-[#fd7730] hover:text-[#fd7730]">
          Previous
        </a>
      ) : (
        <span class="rounded-md border border-[#e5e8ef] px-3 py-1.5 text-[#8b8f99]">Previous</span>
      )}

      {pageItems.map((item) =>
        item.type === "gap" ? (
          <span key={item.value} class="px-2 text-[#8b8f99]">...</span>
        ) : item.value === currentPage ? (
          <span key={`page-${item.value}`} class="rounded-md border border-[#fd7730] bg-[#fff2eb] px-3 py-1.5 text-[#fd7730]">
            {item.value}
          </span>
        ) : (
          <a
            key={`page-${item.value}`}
            href={buildPageHref(item.value)}
            class="rounded-md border border-[#d1d4dd] px-3 py-1.5 transition hover:border-[#fd7730] hover:text-[#fd7730]"
          >
            {item.value}
          </a>
        )
      )}

      {currentPage < totalPages ? (
        <a href={buildPageHref(currentPage + 1)} class="rounded-md border border-[#d1d4dd] px-3 py-1.5 transition hover:border-[#fd7730] hover:text-[#fd7730]">
          Next
        </a>
      ) : (
        <span class="rounded-md border border-[#e5e8ef] px-3 py-1.5 text-[#8b8f99]">Next</span>
      )}
    </nav>
  )
}

