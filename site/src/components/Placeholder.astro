---
const {
    width = "100%",
    height = "300px",
    label = "Image Placeholder"
} = Astro.props;
---

<div
        style={`width:${width}; height:${height};`}
        class="bg-gray-200 border-2 border-dashed border-gray-400 rounded-xl flex items-center justify-center text-gray-500 text-sm"
>
    {label}
</div>