---
import { HUBSPOT_MEETINGS_URL } from "../config/site";

interface Plan {
  name: string;
  subtitle: string;
  price: string;
  features: string[];
  cta: string;
}

interface Props {
  plans: Plan[];
}

const { plans } = Astro.props;
---

<section class="section">
  <div class="container pricing-grid">
    {plans.map((plan, i) => (
      <article class={`card pricing ${i === 1 ? "featured" : ""}`}>
        <h3>{plan.name}</h3>
        <p class="plan-subtitle">{plan.subtitle}</p>
        <p class="plan-price">{plan.price}</p>
        <ul>
          {plan.features.map((feature) => <li>{feature}</li>)}
        </ul>
        <a class="btn btn-outline" href={HUBSPOT_MEETINGS_URL} target="_blank" rel="noopener noreferrer">{plan.cta}</a>
      </article>
    ))}
  </div>
</section>

