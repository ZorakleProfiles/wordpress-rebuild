---
import { Image } from "astro:assets";
import logo from "../assets/figma-import/logo.png";
import { footer } from "../data/site-content";
---

<footer class="rounded-t-[45px] bg-[#22252a] py-14 text-white">
  <div class="section-shell space-y-8">
    <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-center">
      <Image src={logo} alt="Zorakle" class="h-10 w-auto brightness-0 invert" />
      <div class="text-sm text-white/80">
        <p>{footer.address}</p>
        <a href={`mailto:${footer.email}`} class="underline underline-offset-2 hover:text-white transition">
          {footer.email}
        </a>
      </div>
    </div>

    <div class="h-px bg-white/20"></div>

    <div class="flex flex-col gap-2 text-sm text-white/75 md:flex-row md:items-center md:justify-between">
      <p>{footer.copyright}</p>
      <a href="#" class="underline underline-offset-2 hover:text-white transition">Privacy Policy</a>
    </div>
  </div>
</footer>

