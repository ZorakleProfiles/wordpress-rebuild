---
import MainLayout from "../layouts/MainLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getAllPosts, type BlogPost } from "../lib/blog.ts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const paths: Array<{ params: { slug: string }; props: { post: BlogPost } }> = [];

  posts.forEach((post) => {
    paths.push({
      params: { slug: post.slug },
      props: { post }
    });
  });

  return paths;
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const publishedDate = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric"
}).format(new Date(post.publishedAt));

const pageDescription = post.excerpt || `Read ${post.title} on Zorakle Blog.`;
---

<MainLayout title={`${post.title} | Zorakle`} description={pageDescription}>
  <SiteHeader />

  <main class="bg-[#f7f8fb] py-14 md:py-16">
    <article class="section-shell rounded-xl bg-white px-6 py-8 shadow-sm md:px-10 md:py-10">

      <h1 class="mt-4 max-w-5xl font-display text-[42px] leading-tight text-[#22252a] md:text-[56px]">{post.title}</h1>
      <p class="mt-4 text-sm font-semibold text-[#22252a]">Posted on {publishedDate}</p>

      <div class="blog-content mt-8 border-t border-[#d1d4dd] pt-8" set:html={post.contentHtml}></div>
    </article>
  </main>

  <SiteFooter />
</MainLayout>

<style is:global>
  .blog-content {
    color: #3b3e47;
    line-height: 1.8;
    font-size: 1rem;
  }

  .blog-content > * + * {
    margin-top: 1.25rem;
  }

  .blog-content h1,
  .blog-content h2,
  .blog-content h3,
  .blog-content h4 {
    font-family: "MontereyFLF", "Century Gothic", "Avenir Next", sans-serif;
    color: #22252a;
    line-height: 1.25;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-content a {
    color: #fd7730;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-content img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
  }

  .blog-content iframe {
    width: 100%;
    min-height: 320px;
    border: 0;
    border-radius: 0.75rem;
  }

  @media (min-width: 768px) {
    .blog-content iframe {
      min-height: 420px;
    }
  }
</style>

