---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CtaBand from "../components/CtaBand.astro";
import aboutHero from "../assets/figma/about-hero.png";
import rebecca from "../assets/figma/rebecca-placeholder.png";
---

<MainLayout title="About Zorakle" description="33 years building the science of franchise fit.">
  <Header />

  <section class="hero" style={`background-image:linear-gradient(90deg,#22252a 0%, rgba(34,37,42,.4) 65%), url(${aboutHero.src}); background-size: cover;`}>
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>33 years building the science of franchise fit.</h1>
      <p>
        Zorakle Profiles exists because awarding a franchise is too important to leave to a hunch.
        Founded by Rebecca Monet, we help franchise systems make science-backed decisions.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>How Zorakle started - and why it is still franchise-specific.</h2>
      <p style="margin-top:1rem;">
        In the early 1990s, the franchise industry had plenty of assessments, but none were built for business owners.
        Over the past three decades, Zorakle refined a methodology that combines seven validated sciences into one
        franchise-specific platform.
      </p>
    </div>
  </section>

  <section class="section" style="background:#ebecf0;">
    <div class="container grid-2" style="align-items:center;">
      <div>
        <p class="eyebrow">Meet</p>
        <h2>Rebecca Monet</h2>
        <p style="margin-top:1rem; font-style:italic;">CEO & Chief Scientist</p>
        <p style="margin-top:1rem;">
          Rebecca Monet is the founder and chief scientist behind Zorakle Profiles. She is also host of
          The Franchise Woman Podcast, sharing weekly conversations with leaders shaping franchising.
        </p>
      </div>
      <img class="feature-image" src={rebecca.src} alt="Rebecca Monet portrait" />
    </div>
  </section>

  <CtaBand
    title="Let's talk."
    body="Whether you are awarding franchises, matching candidates, or evaluating your own team, start with a 30-minute conversation."
    secondaryLabel="Send a Message"
    secondaryHref="mailto:support@zorakle.net"
  />

  <Footer />
</MainLayout>

