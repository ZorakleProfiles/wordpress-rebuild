---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../utils/paths";
import { HUBSPOT_MEETINGS_URL } from "../config/site";
---

<MainLayout
  title="Zorakle - Franchise Assessment Authority"
  description="Award franchises with science, not gut feeling."
>
  <Header />

  <!-- Hero Section -->
  <section class="hero home-hero figma-hero-band">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">The Franchise Industry's Assessment Authority — Since 2014</p>
        <h1>
          Award franchises with
          <span class="hero-highlight">science not gut feeling.</span>
        </h1>
        <p>
          For 33 years, Zorakle has been the franchise industry's go-to assessment platform.
          Seven validated sciences. One purpose-built methodology.
          Built exclusively for franchising — never adapted from a generic HR tool.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href={withBase("/solutions/franchisors")}>Franchisors</a>
          <a class="btn btn-outline" href={withBase("/solutions/brokers")}>Brokers</a>
        </div>
      </div>
    </div>
  </section>

  <!-- The Science Section -->
  <section class="section the-science figma-science-band">
    <div class="container">
      <p class="eyebrow">The Science</p>
      <h2>Backed by seven sciences. Validated by decades of research.</h2>

      <div class="science-content">
        <div class="science-text">
          <p class="science-highlight">
            <strong>Stanford. Harvard Business School. Gallup. University of Michigan.</strong>
            The frameworks behind Zorakle don't come from a single proprietary algorithm — they come from the most validated work in psychology, organizational behavior, and performance science. We integrate seven of them. That's why Zorakle predicts what others can't.
          </p>
        </div>

        <div class="science-badges">
          <span class="badge">Stanford</span>
          <span class="badge">Harvard Business School</span>
          <span class="badge">Gallup</span>
          <span class="badge">University of Michigan</span>
        </div>

        <div class="science-demo">
          <img src="/images/demo-image.png" alt="Zorakle demo interface" width="531" height="319" />
        </div>
      </div>
    </div>
  </section>

  <!-- Find Your Path Section -->
  <section class="section home-solutions-section find-your-path figma-path-band">
    <div class="container">
      <p class="eyebrow">Find Your Path</p>
      <h2>Zorakle works for <span class="text-accent">both sides</span> of the franchise relationship.</h2>
      <p class="section-subtitle">Pick where you fit. We'll show you exactly how Zorakle helps.</p>
      
      <div class="solutions-grid">
        <!-- Franchisor Card -->
        <article class="solution-card">
          <div class="solution-card-top" aria-hidden="true"></div>
          <p class="card-label">I am a</p>
          <h3>Franchisor</h3>
          <p class="card-tagline">I award franchises.</p>
          <p class="card-description">
            Predict performance before you sign the agreement. Cut bad-fit awards, raise validation scores, and protect your Item 19.
          </p>
          <a class="btn btn-link" href={withBase("/solutions/franchisors")}>
            Solutions for Franchisors →
          </a>
        </article>

        <!-- Broker Card -->
        <article class="solution-card">
          <div class="solution-card-top" aria-hidden="true"></div>
          <p class="card-label">I am a</p>
          <h3>Broker</h3>
          <p class="card-tagline">I match candidates to brands.</p>
          <p class="card-description">
            Stop guessing which brands fit your client. Match with data, recommend confidently, and close more deals.
          </p>
          <a class="btn btn-link" href={withBase("/solutions/brokers")}>
            Solutions for Brokers →
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- Trusted Across The Franchise Industry Section -->
  <section class="section trusted-brands figma-trusted-band">
    <div class="container">
      <div class="brand-header">
        <p class="eyebrow">Trusted Across</p>
        <h2>The Franchise<br />Industry</h2>
        
        <ul class="brand-stats" aria-label="Franchise performance stats">
          <li>33 Years in Franchising</li>
          <li>7 Validated Sciences Built into Every Profile</li>
          <li>[X+] Franchise Systems Served to Date</li>
          <li>[X+] Client Retention Across Our Subscriber Base</li>
        </ul>
      </div>

      <div class="brand-logo-section">
        <p class="logo-label">SOME OF THE BRANDS WE SERVE</p>
        <div class="brand-logos">
          <div class="brand-logo">
            <img src="/images/logo-win-home-inspection-60e3ec.png" alt="WIN Home Inspection" />
          </div>
          <div class="brand-logo">
            <img src="/images/logo-sharkeys.png" alt="Sharkey's Cuts for Kids" />
          </div>
          <div class="brand-logo">
            <img src="/images/logo-amada-senior-care-8191ef.png" alt="Amada Senior Care" />
          </div>
          <div class="brand-logo">
            <img src="/images/logo-american-family-care.png" alt="American Family Care" />
          </div>
        </div>
        <div class="mini-carousel-controls" aria-hidden="true">
          <span class="arrow">&#8592;</span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="dot is-active"></span>
          <span class="dot"></span>
          <span class="dot"></span>
          <span class="arrow">&#8594;</span>
        </div>
      </div>
    </div>
  </section>

  <!-- The Zorakle Difference Section -->
  <section class="section the-difference figma-difference-band">
    <div class="container">
      <p class="eyebrow">The Zorakle Difference</p>
      <h2>Why Zorakle isn't another assessment tool.</h2>
      <p class="section-subtitle">Most assessment tools were built for employees and adapted to fit franchising. We were built for franchising from day one.</p>

      <div class="difference-grid">
        <!-- Card 1 -->
        <article class="difference-card">
          <span class="card-number">01</span>
          <h3>Built for franchise not for HR.</h3>
          <p>
            99% of assessment tools measure employees. We measure business owners. That single distinction changes everything — what we test, how we score, and what we predict. Franchisees aren't employees, and they shouldn't be assessed like them.
          </p>
        </article>

        <!-- Card 2 -->
        <article class="difference-card">
          <span class="card-number">02</span>
          <h3>Seven sciences. Not one.</h3>
          <p>
            While competitors rely on a single personality model, Zorakle integrates seven statistically validated sciences from Stanford, Harvard, Gallup, and the leading research institutions in psychology and organizational behavior — combined through meta-analysis for accuracy no single test can match.
          </p>
        </article>

        <!-- Card 3 -->
        <article class="difference-card">
          <span class="card-number">03</span>
          <h3>Two scoring methods. One unified prediction.</h3>
          <p>
            We use both normative and ipsative scoring, plus topological and dimensional analysis. That's the science behind why Zorakle predicts performance — not just personality.
          </p>
        </article>
      </div>

      <div class="explore-science-cta">
        <a class="btn btn-link btn-orange" href={withBase("/about")}>
          Explore the Science →
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="section testimonials-section figma-testimonial-band">
    <div class="container">
      <p class="eyebrow">Real Systems. Real Results.</p>
      <h2>Franchise leaders use Zorakle to make their <span class="text-accent">biggest decisions</span>.</h2>
      <p class="section-subtitle">Here's what they're saying.</p>

      <div class="testimonial-grid-home">
        <!-- Testimonial 1 -->
        <article class="testimonial-card is-side">
          <p class="testimonial-quote">Zorakle's products have enabled us to target, attract, and motivate the right franchise partners to inquire about our franchise opportunity. I can't imagine growing our system without Rebecca Monet's influence and expertise. Awarding franchises is too big of a decision to leave to chance and a "gut feeling". With Zorakle, we're able to make the decision to award a franchise based fit, values, and aptitude – this alone has had a hugely positive affect on our franchisee validation and our strong Item 19 performance.</p>
          <div class="testimonial-author">
            <img src="/images/testimonial-avatar-marcos-51155f.png" alt="Marcos Moura" class="testimonial-avatar" width="45" height="45" />
            <div>
              <h3>Marcos Moura</h3>
              <p class="testimonial-org">Amada Senior Care</p>
              <p class="testimonial-type">FRANCHISOR</p>
            </div>
          </div>
        </article>

        <!-- Testimonial 2 -->
        <article class="testimonial-card is-featured">
          <p class="testimonial-quote">Zorakle Profiles has been a game changer for our business. This powerful tool has helped us find more precise franchise matches for our clients that fit "their why". Additionally, Zorakle gives us keen insight into how to best work with our clients in terms of their pace and how they will react in different situation, thereby increasing our chances to bring the deal home. This tool is worth 100x what we pay for it.</p>
          <div class="testimonial-author">
            <img src="/images/testimonial-avatar-jack-jill.png" alt="Jack & Jill Johnson" class="testimonial-avatar" width="67" height="67" />
            <div>
              <h3>Jack & Jill Johnson</h3>
              <p class="testimonial-org">Franchise Insiders</p>
              <p class="testimonial-type">BROKER</p>
            </div>
          </div>
        </article>

        <!-- Testimonial 3 -->
        <article class="testimonial-card is-side">
          <p class="testimonial-quote">You guys have given me the tools to see the inner workings of our franchise candidates. I had the "gut" but the unbiased, scientific data gives us direction. I believe in this stuff. It gives me control to create my corporate culture and that leads to every kind of success. Zorakle Profiles is like the key to reading a foreign language of personality.</p>
          <div class="testimonial-author">
            <img src="/images/testimonial-avatar-sean.png" alt="Sean Hart" class="testimonial-avatar" width="45" height="45" />
            <div>
              <h3>Sean Hart</h3>
              <p class="testimonial-org">American Family Care</p>
              <p class="testimonial-type">FRANCHISOR</p>
            </div>
          </div>
        </article>
      </div>
      <div class="mini-carousel-controls testimonials-controls" aria-hidden="true">
        <span class="arrow">&#8592;</span>
        <span class="dot"></span>
        <span class="dot"></span>
        <span class="dot is-active"></span>
        <span class="dot"></span>
        <span class="arrow">&#8594;</span>
      </div>
    </div>
  </section>

  <!-- CTA Band Section -->
  <section class="cta-band">
    <div class="container">
      <div class="cta-content">
        <div class="cta-headline-wrap">
          <img src="/images/zorakle-favicon-circle.png" alt="Zorakle Logo" class="cta-favicon" width="56" height="56" />
          <h2>Stop hoping.<br /><span class="text-white">Start predicting.</span></h2>
        </div>
        <p>
          See how Zorakle works in a 30-minute demo tailored to your franchise system, your performance data, and your specific selection challenges.
        </p>
        <div class="cta-actions">
          <a class="btn btn-link btn-light" href={HUBSPOT_MEETINGS_URL} target="_blank" rel="noopener noreferrer">Book a Demo</a>
          <a class="btn btn-link btn-light" href="mailto:support@zorakle.net">Talk to Our Team</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<style>
  .text-accent {
    color: var(--accent);
  }

  .text-white {
    color: #ffffff;
  }

  .testimonials-section .eyebrow {
    margin-bottom: 0.75rem;
  }

  .testimonials-section {
    background: #ebecf0;
  }

  .figma-hero-band {
    min-height: 690px;
    display: flex;
    align-items: center;
  }

  .hero-highlight {
    color: var(--accent);
    display: block;
  }

  .figma-science-band {
    min-height: 562px;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .figma-path-band {
    min-height: 720px;
    background: #f3f3f3;
    padding-top: 2rem;
    padding-bottom: 2.25rem;
  }

  .figma-trusted-band {
    min-height: 720px;
    padding-top: 2.3rem;
    padding-bottom: 2.4rem;
  }

  .figma-difference-band {
    min-height: 976px;
    padding-top: 2.25rem;
    padding-bottom: 2.35rem;
  }

  .figma-testimonial-band {
    min-height: 813px;
    padding-top: 2.2rem;
    padding-bottom: 2rem;
  }

  .find-your-path .eyebrow {
    margin-bottom: 0.75rem;
  }

  .find-your-path h2 {
    font-size: clamp(2rem, 4.2vw, 3.05rem);
    line-height: 1.14;
    max-width: 16ch;
    margin-bottom: 0.5rem;
  }

  .section-subtitle {
    color: var(--text-soft);
    font-size: 1.125rem;
    line-height: 1.56;
    max-width: 50ch;
    margin: 1rem 0 2.5rem 0;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
    margin-top: 2rem;
  }

  .solution-card {
    border: 1px solid var(--muted);
    border-radius: 3px;
    background: #fff;
    padding: 1.5rem 1.45rem 1.2rem;
    display: flex;
    flex-direction: column;
    position: relative;
    min-height: 258px;
  }

  .solution-card-top {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    border-radius: 3px 3px 0 0;
    background: var(--accent);
  }

  .solution-card .card-label {
    color: var(--text-soft);
    font-size: 1.35rem;
    opacity: 0.38;
    margin: 0 0 0 0;
    font-family: var(--font-body);
    font-weight: 400;
  }

  .solution-card h3 {
    color: var(--accent);
    font-size: 1.95rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  .solution-card .card-tagline {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-style: italic;
    color: var(--text);
    margin: 0.35rem 0 1.05rem 0;
    font-weight: 400;
  }

  .solution-card .card-description {
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.45;
    margin-bottom: 0.9rem;
    flex-grow: 1;
  }

  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1.15rem;
    background: transparent;
    border: 1px solid var(--accent-soft);
    color: var(--text);
    border-radius: var(--radius-sm);
    font-weight: 700;
    font-size: 0.76rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-link:hover {
    background: var(--accent-soft);
    color: #fff;
  }

  .the-science {
    background: #fff;
  }

  .the-science .container {
    max-width: 1360px;
  }

  .science-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.9rem;
    align-items: center;
    margin-top: 1.7rem;
  }

  .science-text p {
    font-size: 0.93rem;
    line-height: 1.52;
    font-style: italic;
  }

  .science-text strong {
    font-weight: 700;
  }

  .science-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.65rem;
  }

  .badge {
    display: inline-block;
    background: var(--surface);
    color: var(--text);
    padding: 0.18rem 0.48rem;
    border-radius: 3px;
    border: 1px solid #d1d4dd;
    font-size: 0.59rem;
    font-weight: 700;
    text-align: center;
  }

  .science-demo {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(164deg, rgba(34, 41, 42, 1) 0%, rgba(9, 204, 156, 1) 100%);
    border-radius: 21px;
    padding: 0.9rem;
    min-height: 372px;
  }

  .science-demo img {
    max-width: 100%;
    height: auto;
  }

  .trusted-brands {
    position: relative;
    background: radial-gradient(circle at 115% 0%, rgba(9, 204, 156, 1) 0%, rgba(19, 135, 109, 1) 0%, rgba(34, 37, 42, 1) 100%);
    color: #fff;
  }

  .brand-header {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 1.4rem;
    margin-bottom: 1.2rem;
    align-items: start;
  }

  .brand-header .eyebrow {
    color: var(--accent);
  }

  .brand-header h2 {
    font-size: clamp(2rem, 4.2vw, 3rem);
    line-height: 1.04;
    color: #fff;
    font-weight: 700;
  }

  .brand-stats {
    display: grid;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.3rem 0 0;
  }

  .brand-stats li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 1rem;
    line-height: 1.55;
    color: #fff;
  }

  .brand-stats li::before {
    content: "";
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 2px rgba(9, 204, 156, 0.18);
  }

  .brand-logo-section {
    margin-top: 1.1rem;
  }

  .logo-label {
    font-size: 0.875rem;
    color: #fff;
    font-weight: 400;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .brand-logos {
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    align-items: center;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60px;
    flex: 1;
  }

  .brand-logo img {
    max-width: 100%;
    height: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .brand-logo:hover img {
    opacity: 1;
  }

  .the-difference {
    background: #fff;
  }

  .the-difference .section-subtitle {
    max-width: 62ch;
    margin-bottom: 1.65rem;
  }

  .difference-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1rem;
  }

  .difference-card {
    background: var(--surface);
    border: 1px solid var(--muted);
    border-radius: 8px;
    padding: 1.2rem 1.1rem 1.1rem;
    display: flex;
    flex-direction: column;
    position: relative;
    min-height: 350px;
  }

  .card-number {
    display: inline-block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .difference-card h3 {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.65rem 0;
    line-height: 1.2;
  }

  .difference-card p {
    font-size: 0.95rem;
    line-height: 1.45;
    color: var(--text);
    opacity: 0.8;
  }

  .explore-science-cta {
    text-align: center;
    margin-top: 1.2rem;
  }

  .btn-orange {
    background: var(--accent-soft);
    color: #fff;
    border-color: var(--accent-soft);
  }

  .btn-orange:hover {
    background: var(--accent-soft-dark);
    border-color: var(--accent-soft-dark);
  }

  .cta-content {
    text-align: left;
    position: relative;
    max-width: 760px;
  }

  .cta-favicon {
    margin-bottom: 0;
    width: 56px;
    height: 56px;
    flex-shrink: 0;
  }

  .cta-headline-wrap {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-bottom: 1rem;
  }

  .cta-band h2 {
    font-size: clamp(2rem, 4.6vw, 3.45rem);
    line-height: 1.05;
    margin-bottom: 0;
  }

  .cta-band p {
    max-width: 68ch;
    margin-inline: 0;
    margin-bottom: 1.25rem;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .btn-light {
    background: var(--accent-soft);
    color: #fff;
    border-color: var(--accent-soft);
  }

  .btn-light:hover {
    background: var(--accent-soft-dark);
    border-color: var(--accent-soft-dark);
  }

  .testimonial-grid-home {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.875rem;
    margin-top: 2rem;
    align-items: center;
  }

  .testimonial-card {
    border: 1px solid var(--muted);
    border-radius: 14px;
    background: #fff;
    padding: 0.95rem;
    display: flex;
    flex-direction: column;
    min-height: 206px;
    overflow: hidden;
  }

  .testimonial-card.is-featured {
    border-color: var(--accent);
    min-height: 275px;
  }

  .testimonial-card.is-side {
    transform: scale(0.92);
  }

  .testimonial-quote {
    font-size: 0.78rem;
    line-height: 1.38;
    color: var(--text);
    margin-bottom: 0.65rem;
    flex-grow: 1;
  }

  .testimonial-author {
    display: flex;
    gap: 0.55rem;
    align-items: flex-start;
  }

  .testimonial-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--muted);
    flex-shrink: 0;
  }

  .testimonial-author h3 {
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 0.25rem 0;
    line-height: 1.16;
  }

  .testimonial-org {
    font-size: 0.9rem;
    line-height: 1.3;
    font-style: italic;
    color: var(--text);
    margin: 0;
  }

  .testimonial-type {
    font-size: 0.74rem;
    font-style: italic;
    color: var(--text);
    margin: 0;
  }

  .mini-carousel-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
  }

  .testimonials-controls {
    color: #7f8590;
    margin-top: 0.75rem;
  }

  .mini-carousel-controls .dot {
    width: 0.28rem;
    height: 0.28rem;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.45;
  }

  .mini-carousel-controls .dot.is-active {
    opacity: 1;
    background: var(--accent);
  }

  .mini-carousel-controls .arrow {
    display: inline-flex;
    width: 1rem;
    justify-content: center;
    opacity: 0.65;
  }

  .home-hero {
    background-image:
