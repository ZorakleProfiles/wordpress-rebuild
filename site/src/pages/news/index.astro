---
import CategoryArchivePage from "../../components/CategoryArchivePage.astro";
import { DEFAULT_ARCHIVE_PAGE_SIZE, getPaginatedPostsByCategorySlug } from "../../lib/wordpress";

const pageData = await getPaginatedPostsByCategorySlug("news", 1, DEFAULT_ARCHIVE_PAGE_SIZE);
---

<CategoryArchivePage
  title="News | Zorakle"
  description="Franchise news and updates from the Zorakle team and network."
  heading="News"
  emptyStateMessage="No posts were found in the News category."
  basePath="/news"
  posts={pageData.posts}
  currentPage={pageData.page}
  totalPages={pageData.totalPages}
/>
