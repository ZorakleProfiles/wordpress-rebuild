---
import BlogList from "../../components/BlogList.astro";
import { DEFAULT_ARCHIVE_PAGE_SIZE, getPaginatedPostsByTag } from "../../lib/wordpress";

const pageData = await getPaginatedPostsByTag("news", 1, DEFAULT_ARCHIVE_PAGE_SIZE);
---

<BlogList
        title="News | Zorakle"
        description="News from the Zorakle network."
        heading="News"
        emptyStateMessage="No news posts were found."
        basePath="/news"
        postBasePath=""
        posts={pageData.posts}
        currentPage={pageData.page}
        totalPages={pageData.totalPages}
/>

