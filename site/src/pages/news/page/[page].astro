---
import CategoryArchivePage from "../../../components/CategoryArchivePage.astro";
import {
  DEFAULT_ARCHIVE_PAGE_SIZE,
  getCategoryPostPageCount,
  getPaginatedPostsByCategorySlug,
  type PaginatedPosts
} from "../../../lib/wordpress";

export async function getStaticPaths() {
  const totalPages = await getCategoryPostPageCount("news", DEFAULT_ARCHIVE_PAGE_SIZE);
  if (totalPages <= 1) {
    return [];
  }

  const pageNumbers = Array.from({ length: totalPages - 1 }, (_unused, index) => index + 2);
  const pageDataByPage = await Promise.all(
    pageNumbers.map((pageNumber) => getPaginatedPostsByCategorySlug("news", pageNumber, DEFAULT_ARCHIVE_PAGE_SIZE))
  );

  return pageNumbers.map((pageNumber, index) => ({
    params: { page: String(pageNumber) },
    props: { pageData: pageDataByPage[index] }
  }));
}

interface Props {
  pageData: PaginatedPosts;
}

const { pageData } = Astro.props;
const pageTitle = `News - Page ${pageData.page} | Zorakle`;
---

<CategoryArchivePage
  title={pageTitle}
  description="Franchise news and updates from the Zorakle team and network."
  heading="News"
  emptyStateMessage="No posts were found in the News category."
  basePath="/news"
  posts={pageData.posts}
  currentPage={pageData.page}
  totalPages={pageData.totalPages}
/>

