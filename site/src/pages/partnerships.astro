---
import { Image } from "astro:assets";
import MainLayout from "../layouts/MainLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { partnerships } from "../data/site-content";
import logoFba from "../assets/figma-import/logo-fba-grey.png";
import logoFbr from "../assets/figma-import/logo-fbr-grey-3971c1.png";
import logoIba from "../assets/figma-import/logo-iba-grey.png";
import logoIfa from "../assets/figma-import/logo-ifa-grey.png";
import logoIfpg from "../assets/figma-import/logo-ifpg-grey.png";

const partnerLogos = {
  FBA: logoFba,
  FBR: logoFbr,
  BAI: logoIba,
  IFA: logoIfa,
  IFPG: logoIfpg
};

const partnershipsWithLogos = partnerships.map((partner) => ({
  ...partner,
  logo: partnerLogos[partner.shortName as keyof typeof partnerLogos]
}));
---

<MainLayout
  title="Partnerships | Zorakle"
  description="Organizations and strategic partnerships that support Zorakle's work across franchising."
>
  <SiteHeader />

  <main class="bg-[#e8e8ea] py-14 md:py-16">
    <section class="section-shell">
      <p class="section-eyebrow">Industry Network</p>
      <h1 class="font-display mt-3 text-[40px] leading-tight text-[#22252a] md:text-[52px]">
        Partnerships
      </h1>
      <p class="mt-5 max-w-3xl text-lg text-[#3b3e47] md:text-xl">
        We work with broker associations, franchise organizations, technology partners, consultants, researchers, and strategic industry partners to improve decision quality at every stage of the franchise lifecycle.
      </p>

      <ul class="mt-10 grid gap-x-10 gap-y-12 md:grid-cols-1">
        {partnershipsWithLogos.map((partner) => (
          <li class="relative border-t-2 border-[#09cc9c] pt-8">
            <div class="flex items-center gap-6">
              {partner.logo ? (
                <Image
                  src={partner.logo}
                  alt={`${partner.name} logo`}
                  class="h-16 w-auto min-w-48 max-w-48 shrink-0 object-contain"
                />
              ) : (
                <span class="font-display text-[44px] leading-none tracking-tight text-[#5a5f69]">
                  {partner.shortName}
                </span>
              )}
              <div class="min-w-0 flex-1">
                <h2 class="font-display pb-1 text-[22px] font-semibold leading-tight text-[#22252a] md:text-[26px]">
                  {partner.name}
                </h2>
                <a href={partner.linkUrl} target="_blank">{partner.linkName}</a>
                <p class="mt-4 text-[18px] leading-[1.6] text-[#3b3e47] md:text-[20px]">
                  {partner.description}
                </p>
              </div>

            </div>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <SiteFooter />
</MainLayout>
