---
import CategoryArchivePage from "../../components/CategoryArchivePage.astro";
import { DEFAULT_ARCHIVE_PAGE_SIZE, getPaginatedPostsByCategorySlug } from "../../lib/wordpress";

const pageData = await getPaginatedPostsByCategorySlug("podcasts", 1, DEFAULT_ARCHIVE_PAGE_SIZE);
---

<CategoryArchivePage
  title="Podcasts | Zorakle"
  description="Podcast episodes and franchise conversations from the Zorakle network."
  heading="Podcasts"
  emptyStateMessage="No posts were found in the Podcasts category."
  basePath="/podcasts"
  posts={pageData.posts}
  currentPage={pageData.page}
  totalPages={pageData.totalPages}
/>
