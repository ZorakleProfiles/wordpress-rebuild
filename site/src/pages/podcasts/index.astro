---
import BlogList from "../../components/BlogList.astro";
import { DEFAULT_ARCHIVE_PAGE_SIZE, getPaginatedPostsByTag } from "../../lib/wordpress";

const pageData = await getPaginatedPostsByTag("podcasts", 1, DEFAULT_ARCHIVE_PAGE_SIZE);
---

<BlogList
  title="Podcasts | Zorakle"
  description="Podcast episodes and franchise conversations from the Zorakle network."
  heading="Podcasts"
  emptyStateMessage="No podcast posts were found."
  basePath="/podcasts"
  postBasePath=""
  posts={pageData.posts}
  currentPage={pageData.page}
  totalPages={pageData.totalPages}
/>

