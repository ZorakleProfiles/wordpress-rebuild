---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PricingCards from "../../components/PricingCards.astro";
import FaqList from "../../components/FaqList.astro";
import CtaBand from "../../components/CtaBand.astro";
import { brokerFaq } from "../../data/siteData";

const plans = [
  {
    name: "Broker Membership",
    subtitle: "Best for active brokerage practices",
    price: "$1,610/year | $149/month",
    features: [
      "SpotOn! Profile",
      "Business Builder Profiles",
      "SpotOn! Match",
      "Training and onboarding",
      "Network visibility"
    ],
    cta: "Join the Network"
  },
  {
    name: "Pay As You Go",
    subtitle: "Flexible assessments as needed",
    price: "$49/assessment",
    features: [
      "SpotOn! Profile",
      "Business Builder Profiles",
      "SpotOn! Match",
      "No long commitment",
      "Upgrade anytime"
    ],
    cta: "Get Started"
  },
  {
    name: "Need Help Choosing?",
    subtitle: "We can map pricing to your deal volume",
    price: "30-minute consult",
    features: [
      "Platform walkthrough",
      "Sample match report",
      "Growth-stage guidance",
      "Implementation timeline",
      "Q&A with team"
    ],
    cta: "Book a Demo"
  }
];
---

<MainLayout title="Pricing for Brokers">
  <Header />

  <section class="page-hero container">
    <p class="eyebrow">For Brokers</p>
    <h1>Broker network membership.</h1>
    <p>
      Match every client to the right brand, close faster, and differentiate with science-backed recommendations.
    </p>
  </section>

  <PricingCards plans={plans} />
  <FaqList items={brokerFaq} />

  <CtaBand
    title="Ready to match smarter?"
    body="Book a 30-minute broker demo and we will walk through the matching engine with real examples."
    primaryLabel="Book a Demo"
    secondaryLabel="Join the Broker Network"
    secondaryHref="/solutions/brokers"
  />

  <Footer />
</MainLayout>

