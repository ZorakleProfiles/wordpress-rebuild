---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<MainLayout title="Privacy Policy">
  <Header />

  <section class="page-hero container">
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p>This page summarizes how contact and assessment information is handled within the Zorakle platform.</p>
  </section>

  <section class="section">
    <article class="container article-wrap">
      <p>
        Zorakle collects information required to deliver assessment services, support platform access, and respond to
        customer requests. Data is used for operational and analytical purposes tied to franchise matching workflows.
      </p>
      <p class="mt-3">
        If you need specific data handling details, retention windows, or account-level requests, contact
        <a href="mailto:support@zorakle.net"> support@zorakle.net</a>.
      </p>
    </article>
  </section>

  <Footer />
</MainLayout>

