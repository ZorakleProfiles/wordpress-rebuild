---
import MainLayout from "../../../layouts/MainLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { blogPosts } from "../../../data/siteData";
import cover from "../../../assets/figma/blog-feature.png";

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
---

<MainLayout title={post.title} description={post.excerpt}>
  <Header />

  <article class="section container article-wrap">
    <p class="eyebrow">{post.category}</p>
    <h1>{post.title}</h1>
    <p class="meta mt-3 text-muted">Posted on {post.date}</p>

    <img class="feature-image mt-4" src={cover.src} alt={post.title} />

    {post.content.map((paragraph) => <p class="mt-3">{paragraph}</p>)}

    <p class="mt-4"><strong>Tags:</strong> {post.tags.join(", ")}</p>
  </article>

  <Footer />
</MainLayout>

