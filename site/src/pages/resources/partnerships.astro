---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ifaLogo from "../../assets/figma/ifa-logo.png";
import fbrLogo from "../../assets/figma/fbr-logo-3971c1.png";
import ifpgLogo from "../../assets/figma/ifpg-logo-8191ef.png";
import fbaLogo from "../../assets/figma/fba-logo-60e3ec.png";
---

<MainLayout title="Partnerships">
  <Header />

  <section class="page-hero container">
    <p class="eyebrow">Partnerships</p>
    <h1>Recognized across the franchise industry.</h1>
    <p>
      Zorakle's work is recognized and supported by leading organizations in franchising.
      These are working relationships built on shared commitment to franchise development done right.
    </p>
  </section>

  <section class="section">
    <div class="container" style="display:grid; gap:1rem;">
      <article class="card blog-card" style="grid-template-columns:220px 1fr; align-items:center;">
        <img src={ifaLogo.src} alt="International Franchise Association" />
        <p><strong>International Franchise Association (IFA)</strong> - The industry's largest membership organization.</p>
      </article>
      <article class="card blog-card" style="grid-template-columns:220px 1fr; align-items:center;">
        <img src={fbrLogo.src} alt="Franchise Business Review" />
        <p><strong>Franchise Business Review</strong> - Independent franchisee satisfaction research and insights.</p>
      </article>
      <article class="card blog-card" style="grid-template-columns:220px 1fr; align-items:center;">
        <img src={ifpgLogo.src} alt="International Franchise Professionals Group" />
        <p><strong>International Franchise Professionals Group (IFPG)</strong> - Supporting consultants with science-backed tools.</p>
      </article>
      <article class="card blog-card" style="grid-template-columns:220px 1fr; align-items:center;">
        <img src={fbaLogo.src} alt="Franchise Brokers Association" />
        <p><strong>Franchise Brokers Association (FBA)</strong> - Connecting broker communities to better candidate matching.</p>
      </article>
    </div>
  </section>

  <Footer />
</MainLayout>

