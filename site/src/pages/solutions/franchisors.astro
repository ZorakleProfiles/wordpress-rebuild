---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

import avatarJackJill from "../../assets/figma-import/avatar-jack-jill.png";
import avatarSean from "../../assets/figma-import/avatar-sean.png";
import avatarMarcos from "../../assets/figma-import/avatar-marcos.png";
import faviconCircle from "../../assets/figma-import/favicon-circle.png";

const processSteps = [
  {
    title: "Define what success looks like in your system.",
    body:
      "We calibrate your profile target using top performers, Item 19 outcomes, and brand-specific requirements so every score is tied to real business results."
  },
  {
    title: "Profile every candidate against your blueprint.",
    body:
      "Candidates complete the assessment once. Zorakle maps fit, coachability, and risk factors against your benchmark using seven validated sciences."
  },
  {
    title: "See the match instantly, and decide with clarity.",
    body:
      "Review clear scoring, role-fit breakdowns, and interview guidance in minutes so your team can award with confidence, not intuition."
  }
];

const productCards = [
  {
    title: "SpotOn! Profile",
    subtitle: "Award better from day one.",
    body:
      "Score candidate fit before you sign. Identify likely top performers, flag hidden risks, and reduce costly mismatches early.",
    cta: "Explore SpotOn! Profiles"
  },
  {
    title: "SpotOn! Blueprint",
    subtitle: "Define your top-performer profile.",
    body:
      "Build your brand-specific success benchmark from real operators so every future candidate is measured against what actually works.",
    cta: "Explore SpotOn! Blueprint"
  },
  {
    title: "SpotOn! Eclipse",
    subtitle: "See blind spots before they show up in P&L.",
    body:
      "Uncover derailers, stress triggers, and leadership gaps early so onboarding and coaching plans can be tailored for success.",
    cta: "Explore SpotOn! Eclipse"
  },
  {
    title: "SpotOn! Match",
    subtitle: "Match people to the right opportunity.",
    body:
      "Compare candidate profiles against territories, models, and brand demands to improve long-term alignment and validation outcomes.",
    cta: "Explore SpotOn! Match"
  }
];

const metrics = [
  {
    title: "Stronger Item 19 performance.",
    body:
      "Franchisees selected with validated fit indicators tend to ramp faster and execute systems more consistently over time."
  },
  {
    title: "Higher validation scores.",
    body:
      "Candidates who are matched to the right brand model hear better stories from operators and move through validation with fewer objections."
  },
  {
    title: "Better retention, fewer transfers.",
    body:
      "Reducing bad-fit awards decreases fallout, resale pressure, and support strain across your development and operations teams."
  },
  {
    title: "Reduced cost to support.",
    body:
      "When owners align with your model, support teams spend less time on preventable issues and more time on growth."
  }
];

const testimonials = [
  {
    quote: "You guys have given me the tools to see the inner workings of our franchise candidates. I had the gut, but the unbiased scientific data gives us direction.",
    name: "Sean Hart",
    company: "American Family Care",
    avatar: avatarSean,
    featured: false
  },
  {
    quote: "Awarding franchises is too big of a decision to leave to chance and gut feeling. With Zorakle, we can make the decision based on fit, values, and aptitude.",
    name: "Keith Mathis",
    company: "WIN Home Inspection",
    avatar: avatarJackJill,
    featured: true
  },
  {
    quote: "This tool is worth 100x what we pay for it. It makes matching candidates to outcomes much clearer for our team.",
    name: "Marcos Moura",
    company: "Amada Senior Care",
    avatar: avatarMarcos,
    featured: false
  }
];

const pricingColumns = [
  {
    tier: "Emerging Franchisor",
    intro: "For systems building the first wave of scalable growth.",
    price: "$4,266/year",
    points: [
      "Core candidate profiling",
      "Basic fit scoring and reports",
      "Franchise development view",
      "Email support",
      "Ideal for smaller pipelines"
    ],
    cta: "Get started"
  },
  {
    tier: "Established Franchisor",
    intro: "For teams awarding consistently across multiple markets.",
    price: "$7,506/year",
    points: [
      "Everything in Emerging",
      "Blueprint calibration tools",
      "Advanced scoring and insights",
      "Decision dashboards for teams",
      "Priority support and training"
    ],
    cta: "Book a demo",
    featured: true,
    badge: "MOST POPULAR"
  },
  {
    tier: "Enterprise",
    intro: "For large organizations with complex development operations.",
    price: "Custom. Let's Talk",
    points: [
      "Everything in Established",
      "Multi-brand governance options",
      "Custom implementation support",
      "Dedicated success partner",
      "Custom data and API pathways"
    ],
    cta: "Contact sales"
  }
];
---

<MainLayout
  title="For Franchisors | Zorakle"
  description="Science-backed franchisee selection tools for franchisor teams that want stronger fit, validation, and performance outcomes."
>
  <SiteHeader />

  <main>
    <section class="border-b border-[#d1d4dd] bg-[#d5dbeb] py-16 md:py-20 lg:py-24">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">For Franchisors</p>
        <h1 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-6xl">
          Award franchises with the confidence of <span class="text-[#09cc9c]">data</span>, not the doubt of a gut feeling.
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-[#3b3e47] md:text-lg">
          Selecting the wrong owner creates expensive downstream friction. Zorakle gives your team a repeatable, validated framework to predict fit before contracts are signed.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#" class="btn-primary">Book a Demo</a>
          <a href="#sample-report" class="btn-primary">See a Sample Report</a>
        </div>
      </div>
    </section>

    <section class="border-b border-[#d1d4dd] bg-white py-16 md:py-20">
      <div class="section-shell">
        <h2 class="max-w-3xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl">
          The wrong franchisee costs more than the right one earns.
        </h2>
        <p class="mt-6 max-w-4xl text-base leading-relaxed text-[#3b3e47] md:text-lg">
          Bad-fit awards drag support resources, lower validation confidence, and create avoidable transfer risk. Zorakle helps you screen for business-owner potential, values alignment, and execution traits before you commit.
        </p>
        <ul class="mt-8 space-y-3 text-[15px] text-[#1f232a] md:text-base">
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#09cc9c]"></span>
            <span>Know which candidates fit your model, not just your culture.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#09cc9c]"></span>
            <span>Move faster and decide with confidence during validation.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#09cc9c]"></span>
            <span>Protect your Item 19 outcomes from avoidable operator mismatch.</span>
          </li>
        </ul>
      </div>
    </section>

    <section class="bg-[radial-gradient(90%_120%_at_90%_0%,#157f73_0%,#1f232a_55%,#12151c_100%)] py-16 text-white md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">How Zorakle Works</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight md:text-5xl">
          A repeatable, science-backed selection process.
        </h2>
        <p class="mt-5 max-w-3xl text-base text-white/80 md:text-lg">
          Build one standard across development, leadership, and validation so every candidate is evaluated with the same objective lens.
        </p>

        <div class="mt-10 space-y-4">
          {processSteps.map((step, idx) => (
            <article class="flex gap-4 rounded-xl border border-white/20 bg-[#1f232a]/70 p-5 shadow-lg md:items-start md:p-6">
              <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#09cc9c] text-sm font-bold text-[#10272a]">
                {idx + 1}
              </div>
              <div>
                <h3 class="text-lg font-bold text-white md:text-xl">{step.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-white/75 md:text-base">{step.body}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-8">
          <a id="sample-report" class="btn-primary" href="#">See Sample Assessment</a>
        </div>
      </div>
    </section>

    <section class="bg-[#f3f3f3] py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">The Tools Franchisors Use Most</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl">
          The Zorakle products franchise systems use most.
        </h2>
        <p class="mt-5 max-w-3xl text-base text-[#3b3e47] md:text-lg">
          Choose one product or combine multiple products to support your full candidate evaluation workflow.
        </p>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {productCards.map((card) => (
            <article class="rounded-xl border border-[#d1d4dd] bg-white p-6 shadow-sm">
              <p class="text-2xl font-bold text-[#1f232a]">{card.title}</p>
              <p class="mt-2 text-sm font-semibold text-[#09cc9c]">{card.subtitle}</p>
              <p class="mt-3 text-sm leading-relaxed text-[#3b3e47] md:text-base">{card.body}</p>
              <a href="#" class="mt-5 inline-flex rounded-md bg-[#fd7730] px-4 py-2 text-sm font-bold text-white transition hover:brightness-95">
                {card.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[radial-gradient(90%_140%_at_100%_0%,#158072_0%,#1f232a_55%,#12151c_100%)] py-16 text-white md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">What Franchisors Gain When Awarding Through Data</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight md:text-5xl">
          The metrics that move when you select <span class="text-[#09cc9c]">with science.</span>
        </h2>

        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {metrics.map((metric) => (
            <article class="rounded-xl border border-white/20 bg-[#1f232a]/65 p-5 md:p-6">
              <h3 class="text-xl font-bold text-white">{metric.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-white/75 md:text-base">{metric.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#f3f3f3] py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">What Franchisors Say</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl">
          Franchise leaders who already trust the science.
        </h2>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {testimonials.map((item) => (
            <article class={`rounded-xl border p-5 ${item.featured ? "border-[#09cc9c] bg-white shadow-lg" : "border-[#d1d4dd] bg-white/85"}`}>
              <div class="flex items-center gap-3">
                <Image src={item.avatar} alt={item.name} class="h-10 w-10 rounded-full object-cover" />
                <div>
                  <p class="text-sm font-bold text-[#1f232a]">{item.name}</p>
                  <p class="text-xs text-[#666a73]">{item.company}</p>
                </div>
              </div>
              <p class="mt-4 text-sm leading-relaxed text-[#3b3e47] md:text-base">"{item.quote}"</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="pricing" class="bg-white py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">Pricing</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl">
          Pricing built for where your system is and where it is going.
        </h2>
        <p class="mt-5 max-w-3xl text-base text-[#3b3e47] md:text-lg">
          Start with the package that matches your current scale and upgrade as your development motion matures.
        </p>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {pricingColumns.map((plan) => (
            <article class={`relative rounded-2xl border p-6 ${plan.featured ? "border-[#1f232a] bg-[#1f232a] text-white" : "border-[#d1d4dd] bg-white"}`}>
              {plan.badge && (
                <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-[#09cc9c] px-3 py-1 text-xs font-bold text-[#1f232a]">
                  {plan.badge}
                </span>
              )}
              <h3 class={`text-2xl font-bold ${plan.featured ? "text-white" : "text-[#1f232a]"}`}>{plan.tier}</h3>
              <p class={`mt-3 text-sm ${plan.featured ? "text-white/80" : "text-[#666a73]"}`}>{plan.intro}</p>
              <p class={`mt-5 text-3xl font-bold ${plan.featured ? "text-white" : "text-[#1f232a]"}`}>{plan.price}</p>

              <ul class="mt-5 space-y-2">
                {plan.points.map((point) => (
                  <li class="flex gap-2 text-sm">
                    <span class={`mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full ${plan.featured ? "bg-[#09cc9c]" : "bg-[#09cc9c]"}`}></span>
                    <span class={plan.featured ? "text-white/85" : "text-[#3b3e47]"}>{point}</span>
                  </li>
                ))}
              </ul>

              <a class={`mt-6 inline-flex rounded-md px-4 py-2 text-sm font-bold transition ${plan.featured ? "bg-[#fd7730] text-white hover:brightness-95" : "bg-[#fd7730] text-white hover:brightness-95"}`} href="#">
                {plan.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#09cc9c] py-14 md:py-16">
      <div class="section-shell flex flex-col gap-7 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <h2 class="font-display text-4xl font-bold leading-tight text-white md:text-5xl">
            Stop awarding on instinct. <br class="hidden md:block" />Start awarding on evidence.
          </h2>
          <p class="mt-4 text-base text-white/90 md:text-lg">
            Get a walkthrough of the exact workflow franchisors use to improve award quality, shorten time-to-decision, and reduce avoidable support costs.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a class="btn-primary" href="#">Book a Demo</a>
            <a class="inline-flex items-center justify-center rounded-lg border border-white/50 px-7 py-3 text-base font-bold text-white transition hover:bg-white/10" href="#">
              Talk to our team
            </a>
          </div>
        </div>

        <Image src={faviconCircle} alt="Zorakle mark" class="h-24 w-24 shrink-0" />
      </div>
    </section>
  </main>

  <SiteFooter />
</MainLayout>

