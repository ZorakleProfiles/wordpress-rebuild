---
import { Image } from "astro:assets";
import MainLayout from "../../layouts/MainLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import PageHero from "../../components/PageHero.astro";

import avatarJackJill from "../../assets/figma-import/avatar-jack-jill.png";
import avatarSean from "../../assets/figma-import/avatar-sean.png";
import avatarMarcos from "../../assets/figma-import/avatar-marcos.png";
import faviconCircle from "../../assets/figma-import/favicon-circle.png";
import heroGraphic from "../../assets/figma-import/Hero Graphic-selection.png";
import businessBuilderReport from "../../assets/figma-import/business_builder.png";
import spotOnProfileReport from "../../assets/figma-import/spoton.png";
import eclipseReport from "../../assets/figma-import/eclipse.png";
import blueprintReport from "../../assets/figma-import/blueprint.png";
import CtaBand from "../../components/CtaBand.astro";
import spotonReferral from "../../assets/figma-import/referrall.png";
import marketingBlueprint from "../../assets/figma-import/marketing_blueprint.png";
import alignmentReport from "../../assets/figma-import/alignment_report.png";

const processSteps = [
  {
    title: "Complete your Franchisor Benchmark Audit.",
    body:
      "Your team completes an audit of key development and operational metrics to establish a benchmark for your system."
  },
  {
    title: "Have your franchisees complete research assessments.",
    body:
      "Franchisees complete a short, validated assessment that measures markers across our 7 sciences. This data is then used to generate your personalized algorithm."
  },
  {
    title: "Get your assessment link and Blueprint.",
    body:
      "Receive your personalized assessment link and Blueprint, which defines who succeeds in your system based on real data from your operators."
  },
  {
    title: "Send assessments to candidates.",
    body:
      "Share your assessment link with prospective franchisees during your development and validation process."
  },
  {
    title: "Review detailed reports for each completed assessment.",
    body:
      "Instantly see how well each candidate matches your franchise model, with clear scoring and decision guidance for your team."
  }
];

const productCards = [
  {
    title: "SpotOn! Profile",
    subtitle: "Candidate breakdown (Franchisor view).",
    body:
      "SpotOn! Profile gives your team the franchisor-only view of those same 7 sciences, with deeper selection insight so you can compare candidates and make award decisions with confidence.",
    image: spotOnProfileReport,
    imageAlt: "SpotOn! Profile"
  },
  {
    title: "SpotOn! Eclipse Report",
    subtitle: "System fit breakdown.",
    body:
      "Eclipse shows overall fit compatibility to your specific system, including how each science contributes to fit, so your team can quickly spot strong alignment and potential risk areas.",
    image: eclipseReport,
    imageAlt: "Eclipse report"
  },
  {
    title: "SpotOn! Referrals",
    subtitle: "Pre-qualified candidates from brokers.",
    image: spotonReferral,
    imageAlt: "SpotOn! Referral screenshot",
    body:
        "SpotOn! Match runs on the broker side. When brokers assess candidates and find strong system alignment, you receive pre-qualified SpotOn! referrals directly for review."
  },
  {
    title: "SpotOn! Blueprint",
    subtitle: "Your custom fit algorithm explained.",
    body:
      "The SpotOn! Blueprint documents exactly how your custom fit algorithm is built from benchmark data, top performers, and brand requirements so your selection process stays consistent over time.",
    image: blueprintReport,
    imageAlt: "SpotOn Blueprint report cover"
  },
  {
    title: "SpotOn! Alignment Report",
    subtitle: "Audit vs. performance breakdown.",
    body:
        "See how your franchisor audit predictions compare to actual franchisee performance. Identify gaps between expectations and outcomes so you can refine your selection model over time.",
    image: alignmentReport,
    imageAlt: "SpotOn Alignment Report"
  },
  {
    title: "SpotOn! Marketing Blueprint",
    subtitle: "Market to your ideal franchisee.",
    body:
        "A data-driven breakdown of how to reach and attract your ideal franchisee profile. Includes recommended messaging, tone, fonts, colors, and channels so your recruitment resonates with the right candidates.",
    image: marketingBlueprint,
    imageAlt: "SpotOn Marketing Blueprint"
  },

];

const metrics = [
  {
    title: "Stronger Item 19 performance.",
    body:
      "Franchisees selected with validated fit indicators tend to ramp faster and execute systems more consistently over time."
  },
  {
    title: "Higher validation scores.",
    body:
      "Candidates who are matched to the right brand model hear better stories from operators and move through validation with fewer objections."
  },
  {
    title: "Better retention, fewer transfers.",
    body:
      "Reducing bad-fit awards decreases fallout, resale pressure, and support strain across your development and operations teams."
  },
  {
    title: "Reduced cost to support.",
    body:
      "When owners align with your model, support teams spend less time on preventable issues and more time on growth."
  }
];

const testimonials = [
  {
    quote: "You guys have given me the tools to see the inner workings of our franchise candidates. I had the gut, but the unbiased scientific data gives us direction.",
    name: "Sean Hart",
    company: "American Family Care",
    avatar: avatarSean,
    featured: false
  },
  {
    quote: "Awarding franchises is too big of a decision to leave to chance and gut feeling. With Zorakle, we can make the decision based on fit, values, and aptitude.",
    name: "Keith Mathis",
    company: "WIN Home Inspection",
    avatar: avatarJackJill,
    featured: true
  },
  {
    quote: "This tool is worth 100x what we pay for it. It makes matching candidates to outcomes much clearer for our team.",
    name: "Marcos Moura",
    company: "Amada Senior Care",
    avatar: avatarMarcos,
    featured: false
  }
];

const pricingColumns = [
  {
    tier: "Emerging Franchisor",
    intro: "For systems building the first wave of scalable growth.",
    price: "$4,266/year",
    points: [
      "Core candidate profiling",
      "Basic fit scoring and reports",
      "Franchise development view",
      "Email support",
      "Ideal for smaller pipelines"
    ],
    cta: "Get started"
  },
  {
    tier: "Established Franchisor",
    intro: "For teams awarding consistently across multiple markets.",
    price: "$7,506/year",
    points: [
      "Everything in Emerging",
      "Blueprint calibration tools",
      "Advanced scoring and insights",
      "Decision dashboards for teams",
      "Priority support and training"
    ],
    cta: "Book a demo",
    featured: true,
    badge: "MOST POPULAR"
  },
  {
    tier: "Enterprise",
    intro: "For large organizations with complex development operations.",
    price: "Custom. Let's Talk",
    points: [
      "Everything in Established",
      "Multi-brand governance options",
      "Custom implementation support",
      "Dedicated success partner",
      "Custom data and API pathways"
    ],
    cta: "Contact sales"
  }
];
---

<MainLayout
  title="For Franchisors | Zorakle"
  description="Science-backed franchisee selection tools for franchisor teams that want stronger fit, validation, and performance outcomes."
>
  <SiteHeader />

  <main>
    <PageHero
      titlePrefix="Award franchises with the confidence of"
      titleHighlight="statistically validated science and data."
      titleSuffix=""
      description="Selecting the wrong owner creates expensive downstream friction. Zorakle gives your team a repeatable, validated framework to predict fit before contracts are signed."
      primaryCta={{ href: "#", label: "Book a Demo" }}
      secondaryCta={{ href: "#sample-report", label: "Take Sample Assessment" }}
      backgroundColor="#f3f3f3"
      minHeightClass="min-h-[620px]"
      rightImage={heroGraphic}
    />

    <section class="border-b border-[#d1d4dd] bg-white py-16 md:py-20">
      <div class="section-shell">
        <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
          <div class="rounded-2xl border border-[#d1d4dd] bg-[#f8f9fb] p-4 md:p-6">
            <Image src={heroGraphic} alt="Wrong fit versus right fit comparison" class="h-auto w-full object-contain" />
          </div>

          <div class="">
            <h2 class="max-w-3xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl lg:ml-auto">
              The wrong franchisee costs more than the right one earns.
            </h2>
            <p class="mt-6 max-w-4xl text-base leading-relaxed text-[#3b3e47] md:text-lg lg:ml-auto">
              Bad-fit awards drag support resources, lower validation confidence, and create avoidable transfer risk. Zorakle helps you screen for business-owner potential, values alignment, and execution traits before you commit.
            </p>
            <ul class="mt-8 space-y-3 text-[15px] text-[#1f232a] md:text-base lg:ml-auto lg:max-w-4xl">
              <li class="flex gap-3 lg:justify-start">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#09cc9c]"></span>
                <span>Know which candidates fit your model, not just your culture.</span>
              </li>
              <li class="flex gap-3 lg:justify-start">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#09cc9c]"></span>
                <span>Move faster and decide with confidence during validation.</span>
              </li>
              <li class="flex gap-3 lg:justify-start">
                <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-[#09cc9c]"></span>
                <span>Protect your Item 19 outcomes from avoidable operator mismatch.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-[#f3f3f3] py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">How Zorakle Works</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight md:text-5xl">
          A repeatable, science-backed selection process.
        </h2>
        <p class="mt-5 max-w-3xl text-base md:text-lg">
          Build one standard across development, leadership, and validation so every candidate is evaluated with the same objective lens.
        </p>

        <div class="mt-10 grid gap-4 text-white md:grid-cols-2 xl:hidden">
          {processSteps.map((step, idx) => (
            <article class="rounded-xl border border-white/20 bg-[#1f232a]/70 p-5 shadow-lg md:p-6">
              <div class="flex items-start gap-4">
                <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[#09cc9c] text-sm font-bold text-[#10272a]">
                  {idx + 1}
                </div>
                <div>
                  <h3 class="text-lg font-bold text-white md:text-xl">{step.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-white/75 md:text-base">{step.body}</p>
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 hidden xl:block">
          <div class="franchisor-workflow-circle">
            <div class="franchisor-workflow-ring" aria-hidden="true"></div>
            {processSteps.map((step, idx) => (
              <article class={`franchisor-workflow-node franchisor-workflow-node-${idx + 1}`}>
                <div class="franchisor-workflow-chip">Step {idx + 1}</div>
                <h3 class="franchisor-workflow-title">{step.title}</h3>
                <p class="franchisor-workflow-body">{step.body}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="mt-8">
          <a id="sample-report" class="btn-primary" href="#">Get Started!</a>
        </div>
      </div>
    </section>

    <style>
      .franchisor-workflow-circle {
        position: relative;
        height: 52rem;
        max-width: 76rem;
        margin: 0 auto;
      }

      .franchisor-workflow-ring {
        position: absolute;
        inset: 50% auto auto 50%;
        width: 34rem;
        height: 34rem;
        transform: translate(-50%, -50%);
        border: 2px dashed #9ca3af;
        border-radius: 9999px;
      }

      .franchisor-workflow-node {
        position: absolute;
        width: 20.5rem;
        border-radius: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(31, 35, 42, 0.74);
        box-shadow: 0 12px 26px rgba(0, 0, 0, 0.16);
        padding: 1.1rem 1.15rem;
      }

      .franchisor-workflow-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background: #09cc9c;
        color: #10272a;
        font-size: 0.75rem;
        font-weight: 700;
        padding: 0.2rem 0.65rem;
      }

      .franchisor-workflow-title {
        margin: 0.65rem 0 0;
        color: #ffffff;
        font-size: 1.05rem;
        line-height: 1.35;
        font-weight: 700;
      }

      .franchisor-workflow-body {
        margin: 0.5rem 0 0;
        color: rgba(255, 255, 255, 0.82);
        font-size: 0.89rem;
        line-height: 1.52;
      }

      .franchisor-workflow-node-1 {
        top: 15%;
        left: 50%;
        transform: translate(-50%, -50%);
      }

      .franchisor-workflow-node-2 {
        top: 40%;
        left: 80%;
        transform: translate(-50%, -50%);
      }

      .franchisor-workflow-node-3 {
        top: 80%;
        left: 75%;
        transform: translate(-50%, -50%);
      }

      .franchisor-workflow-node-4 {
        top: 80%;
        left: 30%;
        transform: translate(-50%, -50%);
      }

      .franchisor-workflow-node-5 {
        top: 40%;
        left: 18%;
        transform: translate(-50%, -50%);
      }
    </style>

    <section class="py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">What Every Franchisor Gets</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl">
          Comprehensive tools included with every plan.
        </h2>
        <p class="mt-5 max-w-3xl text-base text-[#3b3e47] md:text-lg">
          Every franchisor gets both sides of the 7-science assessment (candidate-facing Business Builder and franchisor-facing SpotOn! Profile), Eclipse fit scoring for system alignment, a SpotOn! Blueprint of your custom algorithm, and broker-generated SpotOn! referrals.
        </p>

        <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {productCards.map((card) => (
            <article class="rounded-xl border border-[#d1d4dd] bg-white p-6 shadow-sm">
              {card.image && (
                <div class="mb-5 overflow-hidden rounded-lg border border-[#e3e6ec] bg-[#f8f9fb] p-2">
                  <Image src={card.image} alt={card.imageAlt} class="h-44 w-full object-contain object-top" />
                </div>
              )}
              <p class="text-2xl font-bold text-[#1f232a]">{card.title}</p>
              <p class="mt-2 text-sm font-semibold text-[#09cc9c]">{card.subtitle}</p>
              <p class="mt-3 text-sm leading-relaxed text-[#3b3e47] md:text-base">{card.body}</p>
            </article>
          ))}
        </div>

        <div class="mt-10">
          <a href="#" class="inline-flex rounded-md bg-[#fd7730] px-6 py-3 text-base font-bold text-white transition hover:brightness-95">
            View Sample Reports
          </a>
        </div>
      </div>
    </section>

    <section class="bg-[#f3f3f3] py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">What Franchisors Gain When Awarding Through Data</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight md:text-5xl">
          The metrics that move when you select <span class="text-[#09cc9c]">with science.</span>
        </h2>

        <div class="mt-12 border-l-4 border-[#09cc9c]/30 pl-6 md:pl-10">
          {metrics.map((metric, idx) => (
            <article class={`relative ${idx !== metrics.length - 1 ? "pb-8 md:pb-12" : ""}`}>
              {/* Timeline dot */}
              <div class="absolute left-[-2.1rem] top-1 h-4 w-4 rounded-full border-2 border-[#09cc9c]/60 bg-white md:left-[-3.1rem]"></div>

              <div>
                <h3 class="text-xl font-bold leading-tight text-[#1f232a] md:text-2xl">{metric.title}</h3>
                <p class="mt-2 max-w-3xl text-sm leading-relaxed text-[#3b3e47] md:text-base">{metric.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class=" py-16 md:py-20">
      <div class="section-shell">
        <p class="font-display text-[17px] text-[#09cc9c] md:text-[20px]">What Franchisors Say</p>
        <h2 class="mt-4 max-w-4xl font-display text-4xl font-bold leading-tight text-[#1f232a] md:text-5xl">
          Franchise leaders who already trust the science.
        </h2>

        <div class="mt-10 grid gap-4 lg:grid-cols-3">
          {testimonials.map((item) => (
            <article class={`rounded-xl border p-5 ${item.featured ? "border-[#09cc9c] bg-white shadow-lg" : "border-[#d1d4dd] bg-white/85"}`}>
              <div class="flex items-center gap-3">
                <Image src={item.avatar} alt={item.name} class="h-10 w-10 rounded-full object-cover" />
                <div>
                  <p class="text-sm font-bold text-[#1f232a]">{item.name}</p>
                  <p class="text-xs text-[#666a73]">{item.company}</p>
                </div>
              </div>
              <p class="mt-4 text-sm leading-relaxed text-[#3b3e47] md:text-base">"{item.quote}"</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <CtaBand />
  </main>

  <SiteFooter />
</MainLayout>



