---
import MainLayout from "../../layouts/MainLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CtaBand from "../../components/CtaBand.astro";
import TestimonialGrid from "../../components/TestimonialGrid.astro";
---

<MainLayout title="Solutions for Franchisors">
  <Header />

  <section class="page-hero page-hero-solutions container">
    <p class="eyebrow">For Franchisors</p>
    <h1>Award franchises with confidence of data, not doubt of gut feeling.</h1>
    <p>
      Every franchise you award is a multi-year bet on a person. Zorakle predicts performance before the agreement is signed.
    </p>
  </section>

  <section class="section dark-section solutions-workflow">
    <div class="container">
      <p class="eyebrow">The Franchisor Workflow</p>
      <h2>A repeatable science-backed selection process.</h2>
      <div class="grid-2 mt-4">
        <article class="card card-pad-md">
          <h3>1. SpotOn! Profile</h3>
          <p>Profile every candidate with a 20-minute assessment across seven sciences.</p>
        </article>
        <article class="card card-pad-md">
          <h3>2. SpotOn! Blueprint</h3>
          <p>Build a benchmark from your highest performers and define what success looks like.</p>
        </article>
        <article class="card card-pad-md">
          <h3>3. SpotOn! Eclipse</h3>
          <p>Compare candidate-to-blueprint fit and identify strengths, gaps, and risk at a glance.</p>
        </article>
        <article class="card card-pad-md">
          <h3>4. SpotOn! Match</h3>
          <p>Receive pre-qualified leads already aligned to your brand's scientific fit profile.</p>
        </article>
      </div>
    </div>
  </section>

  <TestimonialGrid />

  <CtaBand
    title="Stop awarding on instinct. Start awarding on evidence."
    body="Book a 30-minute demo to see how your blueprint would be built and how eclipse reports guide award decisions."
  />

  <Footer />
</MainLayout>
