---
import MainLayout from "../layouts/MainLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { testimonials } from "../data/site-content";
---

<MainLayout
  title="Testimonials | Zorakle"
  description="Read all broker and franchisor testimonials about using Zorakle to make better franchise decisions."
>
  <SiteHeader />

  <main class="bg-white py-16 md:py-20">
    <section class="section-shell">
      <p class="section-eyebrow">Testimonials</p>
      <h1 class="section-title max-w-4xl">What brokers and franchisors are saying.</h1>
      <p class="mt-4 text-sm text-[#666a73]">All testimonials in one place.</p>

      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {testimonials.map((item) => (
          <article class="testimonial-card">
            <div class="testimonial-card-head">
              <div class="min-w-0">
                <p class="truncate text-base font-bold text-[#22252a]">{item.name}</p>
                <p class="truncate text-sm text-[#3b3e47]">{item.company}</p>
              </div>
              <span class="testimonial-quote-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7.5 16.5C5.57 16.5 4 14.93 4 13C4 11.07 5.57 9.5 7.5 9.5H8.5V6.5H5.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                  <path d="M16.5 16.5C14.57 16.5 13 14.93 13 13C13 11.07 14.57 9.5 16.5 9.5H17.5V6.5H14.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </div>

            <p class="testimonial-type mt-3">{item.type}</p>
            <p class="mt-4 text-sm leading-6 text-[#22252a] md:text-[0.95rem] md:leading-7">{item.quote}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
</MainLayout>

<style>
  .testimonial-card {
    border-radius: 1rem;
    border: 1px solid #d1d4dd;
    background: #f3f3f3;
    padding: 1.1rem;
    min-height: 13.5rem;
  }

  .testimonial-card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .testimonial-type {
    margin: 0;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666a73;
  }

  .testimonial-quote-mark {
    margin: 0;
    width: 1.3rem;
    height: 1.3rem;
    color: #fd7730;
    flex-shrink: 0;
  }

  .testimonial-quote-mark svg {
    width: 100%;
    height: 100%;
  }

  @media (min-width: 1024px) {
    .testimonial-card {
      min-height: 14.5rem;
      padding: 1.3rem;
    }
  }
</style>
